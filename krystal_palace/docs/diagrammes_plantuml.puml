@startuml Diagramme_Cas_Utilisation_Krystal_Palace
title Diagramme de Cas d'Utilisation\nKrystal Palace Hôtel Yaoundé

skinparam backgroundColor #0D0D0D
skinparam usecaseBackgroundColor #1E1E16
skinparam usecaseBorderColor #C9A84C
skinparam usecaseArrowColor #C9A84C
skinparam usecaseFontColor #F7F3EA
skinparam actorBackgroundColor #2A2A1E
skinparam actorBorderColor #C9A84C
skinparam actorFontColor #F7F3EA
skinparam titleFontColor #C9A84C
skinparam titleFontSize 15
skinparam rectangleBackgroundColor #0D0D0D
skinparam rectangleBorderColor #C9A84C
skinparam rectangleFontColor #C9A84C

actor "🧳 Client Hôtel" as CLIENT
actor "🔑 Administrateur" as ADMIN
actor "⚙️ Passerelle\nBACnet :8001" as GW
actor "🎮 Simulateur\nYABE :47808" as YABE
actor "🗄️ SQLite\nDB Browser" as DB

rectangle "Système Krystal Palace Hôtel Yaoundé" {

  rectangle "🌐  Interface Client — GET /  (port 8000)" {
    usecase "UC01\nVisualiser les offres\n(chambres & tarifs)" as UC01
    usecase "UC02\nChoisir type de chambre\n(Standard · Sup. · Suite)" as UC02
    usecase "UC03\nSélectionner les dates\n(arrivée / départ)" as UC03
    usecase "UC04\nRenseigner son identité\n(CNI · Nom · Tél · Email)" as UC04
    usecase "UC05\nConfirmer la réservation\nPOST /api/reserver" as UC05
    usecase "UC06\nRecevoir confirmation\n(Réf + Total FCFA)" as UC06
  }

  rectangle "🔑  Interface Admin — GET /admin  (port 8000)" {
    usecase "UC07\nSe connecter\n(admin / krystal2024)" as UC07
    usecase "UC08\nConsulter tableau de bord\n(nb clients, réservations,\nen cours)" as UC08
    usecase "UC09\nGérer les clients\n(Lister · Créer · Supprimer)" as UC09
    usecase "UC10\nGérer les réservations\n(Lister · Modifier · Supprimer)" as UC10
    usecase "UC11\nAttribuer numéro de chambre\n(PATCH statut + numero)" as UC11
    usecase "UC12\nValider Check-In\n(statut → En cours)" as UC12
    usecase "UC13\nValider Check-Out\n(statut → Terminée)" as UC13
    usecase "UC14\nAnnuler une réservation\n(statut → Annulée)" as UC14
  }

  rectangle "⚙️  Passerelle BACnet — port 8001" {
    usecase "UC15\nRecevoir webhook\nRESERVATION_CONFIRMEE" as UC15
    usecase "UC16\nPlanifier job\npré-refroidissement (J-30min)" as UC16
    usecase "UC17\nRecevoir webhook CHECK_IN\n→ Démarrage immédiat clim" as UC17
    usecase "UC18\nRecevoir webhook CHECK_OUT\n→ Arrêt différé (10 min)" as UC18
    usecase "UC19\nRecevoir webhook ANNULATION\n→ Supprimer jobs planifiés" as UC19
    usecase "UC20\nCommande BACnet/IP\nWrite Property (AO/BO/MV)" as UC20
    usecase "UC21\nDiagnostic /health\n(jobs en cours + YABE)" as UC21
    usecase "UC22\nTest manuel\n/test/demarrer ou /arreter" as UC22
  }

  rectangle "🗄️  SQLite (DB Browser)" {
    usecase "UC23\nStockage clients\n(INSERT / UPDATE / SELECT)" as UC23
    usecase "UC24\nStockage réservations\n(INSERT / UPDATE / SELECT)" as UC24
    usecase "UC25\nVue v_reservations_detail\n(JOIN clients + reservations)" as UC25
  }
}

