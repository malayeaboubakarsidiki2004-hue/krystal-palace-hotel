# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Krystal Palace Hôtel Yaoundé v7
# Variables d'environnement locales (secrets de développement).
# Ce fichier EST versionné : copiez-le en ".env" puis adaptez les valeurs.
# Les valeurs ci-dessous correspondent aux valeurs par défaut créées par
# database/create_database_postgresql.sql — ne rien changer si vous suivez
# le guide d'installation tel quel.
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=krystal_palace
DB_USER=krystal_user
DB_PASSWORD=krystal2024

# Utilisée directement par krystal_palace/main.py (priorité sur DB_HOST/... ci-dessus)
DATABASE_URL=postgresql://krystal_user:krystal2024@localhost:5432/krystal_palace

# ── Compte administrateur (dashboard /admin) ──────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=krystal2024

# ── Passerelle BACnet (doit être IDENTIQUE des deux côtés) ────────────────────
GATEWAY_URL=http://127.0.0.1:8001
GATEWAY_TOKEN=secret-gateway-token

# ── Simulateur YABE (BACnet/IP) — lu par gateway/config.py ────────────────────
BACNET_DEVICE_IP=127.0.0.1
BACNET_DEVICE_PORT=47808
BACNET_TIMEOUT=10
YABE_DEVICE_INSTANCE=1001

# ── Orange Money (numéro récepteur simulé) ────────────────────────────────────
OM_NUMERO_RECEPTEUR=+237655448731
